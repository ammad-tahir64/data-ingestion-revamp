{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "E4Score": "Debug"
    }
  },
  "ConnectionStrings": {
    "E4ScorePlatform": "Server=<sql-server>;Database=ezcheckin;User Id=<user>;Password=<password>;TrustServerCertificate=True;"
  },
  "Redis": {
    "ConnectionString": "<redis-connection-string>"
  },
  "Azure": {
    "EventHub": {
      "ConnectionString": "<event-hub-connection-string>",
      "Name": "e4-device-telemetry",
      "ConsumerGroup": "e4-processing-cg"
    },
    "Storage": {
      "ConnectionString": "<storage-connection-string>",
      "CheckpointContainer": "event-hub-checkpoints"
    },
    "ServiceBus": {
      "ConnectionString": "<service-bus-connection-string>",
      "DeadLetterQueue": "e4.dlq.device-telemetry"
    }
  },
  "SqlBatch": {
    "BatchSize": 500,
    "FlushIntervalSeconds": 2,
    "MaxRetryAttempts": 3
  }
}
